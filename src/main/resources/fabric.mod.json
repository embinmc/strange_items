{
	"schemaVersion": 1,
	"id": "strangeitems",
	"version": "${version}",
	"name": "Strange Items",
	"description": "Allows tools and other items to track certain statistics on a per-stack basis.",
	"authors": [
		"Embin"
	],
	"contributors": [
		"StarmanMine142"
	],
	"contact": {
		"sources": "https://github.com/embinmc/strange_items",
		"issues": "https://github.com/embinmc/strange_items/issues"
	},
	"license": "MIT",
	"icon": "assets/strangeitems/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": ["embinmc.mod.strangeitems.StrangeItems"],
		"client": ["embinmc.mod.strangeitems.client.StrangeItemsClient"],
		"modmenu": ["embinmc.mod.strangeitems.ModMenuIntegration"]
	},
	"accessWidener": "strangeitems.accesswidener",
	"mixins": [
		"strangeitems.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": ">=26.1-pre.3",
		"java": ">=25",
		"fabric-registry-sync-v0": "*",
		"vanillaoptionsapi": ">=1.0.0",
		"fabric-lifecycle-events-v1": "*",
		"fabric-key-mapping-api-v1": "*",
		"fabric-command-api-v2": "*",
		"fabric-resource-loader-v1": "*",
		"fabric-api-base": "*"
	},
	"suggests": {
		"tooltipscroll": "*"
